# Runtime
NEXUS_ENV=development
NEXUS_LOG_LEVEL=INFO
# Use 127.0.0.1 for a private local server. Use 0.0.0.0 only when Docker,
# a VM, or another device on your network must reach this process.
NEXUS_HOST=127.0.0.1
NEXUS_PORT=8000
NEXUS_WORKERS=1
# Comma-separated IP/CIDR list for trusted reverse proxies. Never use * in live environments.
NEXUS_FORWARDED_ALLOW_IPS=127.0.0.1
NEXUS_GRACEFUL_SHUTDOWN_SECONDS=30
NEXUS_HTTP_CONCURRENCY_LIMIT=100
NEXUS_HTTP_BACKLOG=256
# Docker Compose host-side port; not consumed by the Python settings model.
COGNEXUS_PUBLISHED_PORT=8000

# OpenAI - required for live runs. Dry runs and unit tests do not call OpenAI.
OPENAI_API_KEY=
NEXUS_ORCHESTRATOR_MODEL=gpt-5.5
NEXUS_SPECIALIST_MODEL=gpt-5.4-mini
NEXUS_GUARDRAIL_MODEL=gpt-5.4-mini
NEXUS_COMPACTION_MODEL=gpt-5.4-mini
NEXUS_MODEL_VALIDATION_MODE=warn
NEXUS_MODEL_VALIDATION_TTL_SECONDS=300
NEXUS_MODEL_VALIDATION_ERROR_TTL_SECONDS=30
NEXUS_MODEL_VALIDATION_MAX_PAGES=20
NEXUS_PROMPT_CACHE_RETENTION=24h
NEXUS_OPENAI_TIMEOUT_SECONDS=120
NEXUS_OPENAI_TRANSPORT_RETRIES=1
NEXUS_MODEL_RETRIES=1
NEXUS_MAX_CONCURRENT_RUNS=2
NEXUS_QUEUE_TIMEOUT_SECONDS=30

# Sessions: sqlite | redis | stateless
NEXUS_SESSION_BACKEND=sqlite
NEXUS_ALLOW_SQLITE_FALLBACK=true
NEXUS_ALLOW_STATELESS_FALLBACK=false
NEXUS_SQLITE_PATH=./data/nexus_sessions.db
NEXUS_SESSION_CACHE_MAX_ENTRIES=128
NEXUS_SESSION_CACHE_TTL_SECONDS=900
REDIS_URL=redis://redis:6379/0
NEXUS_REDIS_KEY_PREFIX=nexus:session
NEXUS_REDIS_TTL_SECONDS=604800
NEXUS_REDIS_CONNECT_TIMEOUT_SECONDS=2
NEXUS_REDIS_SOCKET_TIMEOUT_SECONDS=5
NEXUS_REDIS_MAX_CONNECTIONS=16
NEXUS_COMPACTION_ENABLED=true
NEXUS_COMPACTION_CANDIDATE_ITEMS=10
NEXUS_SESSION_SUMMARY_MAX_CHARS=1200
NEXUS_SESSION_SUMMARY_ITEM_LIMIT=24

# API and security
# Create a long random value before sharing this server with anyone else:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
NEXUS_API_KEY=
NEXUS_RATE_LIMIT=30/minute
# Optional. Live Redis deployments automatically reuse REDIS_URL for distributed limits.
NEXUS_RATE_LIMIT_STORAGE_URI=
NEXUS_MAX_INPUT_CHARS=50000
NEXUS_MAX_REQUEST_BYTES=262144
NEXUS_MAX_OUTPUT_CHARS=200000
NEXUS_REQUEST_TIMEOUT_SECONDS=180
NEXUS_STREAM_CHUNK_CHARS=768
NEXUS_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
NEXUS_TRUSTED_HOSTS=localhost,127.0.0.1,testserver
NEXUS_ENABLE_DOCS=true

# Observability - sensitive trace capture is intentionally impossible to enable.
NEXUS_OTEL_ENABLED=true
NEXUS_OTEL_CONSOLE=false
NEXUS_OTEL_SAMPLE_RATIO=0.25
OTEL_SERVICE_NAME=cognexus
OTEL_EXPORTER_OTLP_ENDPOINT=
TRACE_INCLUDE_SENSITIVE=false
OPENAI_AGENTS_TRACE_INCLUDE_SENSITIVE_DATA=false
OPENAI_AGENTS_DISABLE_TRACING=

# Orchestration bounds
MAX_TURNS=12
MAX_TOOL_CALLS_PER_TIER=5

# Portable Agent Skills (canonical path: .agents/skills)
NEXUS_SKILLS_ENABLED=true
NEXUS_SKILLS_PATH=.agents/skills
NEXUS_SKILL_MAX_FILE_BYTES=256000
NEXUS_SKILL_MAX_RESOURCE_BYTES=1000000
NEXUS_SKILL_ACTIVATION_MAX_CHARS=40000
NEXUS_SKILL_CATALOG_MAX_CHARS=24000
NEXUS_SKILL_CACHE_TTL_SECONDS=60
# Optional comma-separated allow/deny lists. Leave blank to allow all discovered skills.
NEXUS_SKILL_ALLOWED_NAMES=
NEXUS_SKILL_DENIED_NAMES=
