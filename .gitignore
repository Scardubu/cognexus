# =============================================================================
# cognexus — .gitignore
# Stack: Python · FastAPI · OpenAI Agents SDK · SQLite · pytest · ruff · mypy
# =============================================================================


# =============================================================================
# 🔐 SECRETS & ENVIRONMENT — never commit these
# =============================================================================

# Environment variable files (all variants)
.env
.env.*
!.env.example
!.env.sample
!.env.template

# Local config overrides (12-factor pattern)
*.local.toml
*.local.yaml
*.local.yml
*.local.json

# Private keys, certificates, credentials
*.pem
*.key
*.p8
*.p12
*.pfx
*.cert
*.crt
*.der
id_rsa
id_ed25519
*.pub


# =============================================================================
# 🐍 PYTHON RUNTIME
# =============================================================================

# Byte-compiled / optimised / DLL files
*.py[cod]
*$py.class

# CPython cache (all depths)
**/__pycache__/

# C extensions
*.so

# Distribution / packaging
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
sdist/
var/
wheels/
share/python-wheels/
MANIFEST

# PyInstaller
*.manifest
*.spec


# =============================================================================
# 🧪 TESTING & COVERAGE
# =============================================================================

# pytest
**/.pytest_cache/
.benchmarks/
.hypothesis/
**/prof/

# Coverage
.coverage
.coverage.*
coverage.xml
coverage.json
*.cover
*.py,cover
htmlcov/

# tox / nox
.tox/
.nox/


# =============================================================================
# 🔍 LINTING, TYPE-CHECKING & FORMATTING CACHES
# =============================================================================

**/.mypy_cache/
**/.ruff_cache/
.dmypy.json
dmypy.json
**/.pytype/

# pyright
pyrightconfig.json


# =============================================================================
# 🌐 VIRTUAL ENVIRONMENTS
# =============================================================================

.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
virtualenv/
.virtualenv/
.python-version


# =============================================================================
# 📦 PACKAGE MANAGERS
# =============================================================================

# pip
pip-log.txt
pip-delete-this-directory.txt

# Poetry (lock file should be committed — keep poetry.lock tracked)
# .venv/ already covered above

# pipenv
Pipfile.lock

# uv (Astral's fast pip replacement)
.uv/
uv.lock

# Node (if any frontend tooling or scripts exist)
node_modules/
.npm/
.pnp
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# =============================================================================
# 🤖 AI / AGENT FRAMEWORK ARTIFACTS
# =============================================================================

# OpenAI Agents SDK — local trace/run stores
traces/
runs/
.openai_cache/

# LangChain / LangGraph / generic agent cache
.langchain/
.agent_cache/
agent_runs/

# Vector store local indices (FAISS, Chroma, etc.)
*.faiss
*.index
chroma_db/
vector_store/
embeddings_cache/

# Model weights and checkpoints (large binary files)
*.bin
*.safetensors
*.ckpt
*.pt
*.pth
*.onnx

# Jupyter (used in AI/ML experimentation)
**/.ipynb_checkpoints/
*.ipynb


# =============================================================================
# 🗄️ DATABASES & DATA FILES
# =============================================================================

# SQLite databases and WAL/SHM sidecar files (all paths, all depths)
**/*.db
**/*.db-wal
**/*.db-shm
**/*.db-journal
**/*.sqlite
**/*.sqlite3

# Data directory — runtime-generated content
# (add explicit exceptions below if you have seed/fixture data to commit)
data/


# =============================================================================
# 📝 LOGS & RUNTIME OUTPUT
# =============================================================================

# Log files (all rotated variants)
*.log
*.log.*
logs/

# PIDs (uvicorn, gunicorn, celery workers)
*.pid
*.pid.lock

# Profiling output
*.prof
*.lprof
*.pstats

# Celery / task queue
celerybeat-schedule
celerybeat-schedule.*
celerybeat.pid


# =============================================================================
# 🐳 DOCKER & INFRASTRUCTURE
# =============================================================================

# Docker Compose local overrides (keep docker-compose.yml tracked)
docker-compose.override.yml
docker-compose.override.yaml
.dockerenv

# Terraform / IaC state (if applicable)
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl


# =============================================================================
# 🛠️ IDE & EDITOR
# =============================================================================

# VS Code — only ignore non-shareable settings
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains (PyCharm, etc.)
.idea/
*.iml
*.iws

# Vim / Neovim
*.swp
*.swo
*~
Session.vim
.netrwhist

# Emacs
*#
.#*
\#*#


# =============================================================================
# 💻 OPERATING SYSTEM ARTIFACTS
# =============================================================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory


# =============================================================================
# 📁 PROJECT-SPECIFIC — cognexus / NEXUS
# =============================================================================

# Local agent behaviour overrides (never push — author-local only)
AGENTS.override.md

# NEXUS benchmark and report outputs
artifacts/

# STRIDE threat model working drafts (keep final only if desired)
# threat_model.draft.*

# Temporary files
*.tmp
*.bak
*.orig
*.swp